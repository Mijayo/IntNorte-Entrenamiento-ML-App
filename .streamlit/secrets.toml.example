# ============================================================
# PLANTILLA DE CREDENCIALES — SÍ se puede subir a GitHub
# Copia este fichero como secrets.toml y rellena los valores
# ============================================================

# Clave API de Google Gemini (https://aistudio.google.com/app/apikey)
GENAI_API_KEY = "..."

[supabase]
url    = "https://<tu-proyecto>.supabase.co"
key    = "SUPABASE_ANON_KEY"
bucket = "modelos-ml"

[users.admin]
password = "CHANGE_ME"
role = "admin"
name = "Administrador"
icon = "👑"

[users.admin.permissions]
entrenar_modelos = true
ver_metricas_tecnicas = true
ver_predicciones = true
exportar = true
gestionar_usuarios = true
ver_grid_search = true
ver_acf_pacf = true

[users.gerente_compras]
password = "CHANGE_ME"
role = "manager"
name = "Gerente de Compras"
icon = "💼"

[users.gerente_compras.permissions]
entrenar_modelos = false
ver_metricas_tecnicas = false
ver_predicciones = true
exportar = true
gestionar_usuarios = false
ver_grid_search = false
ver_acf_pacf = false

[users.analista]
password = "CHANGE_ME"
role = "analyst"
name = "Analista de Datos"
icon = "📊"

[users.analista.permissions]
entrenar_modelos = true
ver_metricas_tecnicas = true
ver_predicciones = true
exportar = true
gestionar_usuarios = false
ver_grid_search = true
ver_acf_pacf = true

[users.vendedor]
password = "CHANGE_ME"
role = "viewer"
name = "Vendedor"
icon = "👁️"

[users.vendedor.permissions]
entrenar_modelos = false
ver_metricas_tecnicas = false
ver_predicciones = true
exportar = false
gestionar_usuarios = false
ver_grid_search = false
ver_acf_pacf = false
